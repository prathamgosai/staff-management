# ─────────────────────────────────────────────────────────────
# WorkforceIQ — Environment Variables Template
# Copy to .env and fill in values before running any service.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=WorkforceIQ
APP_URL=http://localhost:3000

# ── Database (PostgreSQL 16 + TimescaleDB) ────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workforceiq
DB_USER=workforceiq_user
# REQUIRED — generate a strong value, never use a default:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DB_PASSWORD=__CHANGE_ME__
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Auth ──────────────────────────────────────────────────
# REQUIRED — generate unique random secrets, never use a default:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=__CHANGE_ME__
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=__CHANGE_ME__
JWT_REFRESH_EXPIRES_IN=7d

# ── Magic links (read-only "My Week" for staff without logins) ────────────────
# Presence enables the feature; a long random value, DISTINCT from JWT_SECRET.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
MAGIC_LINK_SECRET=
# Set true to also send links to staff who DO have a login (default: login-less only).
MAGIC_LINK_ALL_STAFF=false

# ── API Service ───────────────────────────────────────────────
API_PORT=4000
API_PREFIX=api/v1

# ── ML Service (Python FastAPI) ───────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=internal_ml_service_key

# ── Next.js Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=WorkforceIQ

# ── WhatsApp Business API ─────────────────────────────────────
# Provider: meta | twilio | gupshup
WHATSAPP_PROVIDER=meta
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Email ─────────────────────────────────────────────────────
# Implemented providers: "mock" (default — logs only, sends nothing) and
# "sendgrid" (real, via the SendGrid v3 HTTPS API). SES is NOT wired yet.
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@workforceiq.app
EMAIL_FROM_NAME=WorkforceIQ

# SendGrid (required when EMAIL_PROVIDER=sendgrid). EMAIL_FROM must be a
# SendGrid-verified single sender or a verified domain.
SENDGRID_API_KEY=

# AWS SES (placeholder — provider not implemented)
AWS_SES_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Object Storage (S3 / GCS / MinIO) — legacy scaffold, unused ───────────────
STORAGE_PROVIDER=minio
STORAGE_BUCKET=workforceiq-docs
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# ── Staff Documents (Phase 1 — Employee Documents module) ─────────────────────
# App-layer AES-256-GCM key for document bytes + numbers. 32 bytes as hex(64) or base64.
# REQUIRED in production (without it, documents are stored UNENCRYPTED — dev only):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_ENCRYPTION_KEY=
# Optional dedicated HMAC secret for short-lived signed download URLs (defaults to the
# encryption key). node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DOCUMENT_SIGN_SECRET=
# Supabase Storage (private bucket) — the chosen document store. When unset, document bytes
# fall back to encrypted-in-DB (fine for dev; use Storage in production).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DOCUMENTS_BUCKET=staff-documents
# Max decoded document size in bytes (default 10 MB) and the JSON body limit (default 16mb).
MAX_DOCUMENT_BYTES=10485760
MAX_JSON_BODY=16mb

# ── OAuth2 / SSO (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_ML_FORECASTING=false
ENABLE_WHATSAPP=false
ENABLE_BIOMETRIC_SYNC=false
