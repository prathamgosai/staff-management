{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "isolatedModules": true }]
  },
  "moduleNameMapper": {
    "^@workforceiq/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
  },
  "testTimeout": 60000,
  "forceExit": true
}
